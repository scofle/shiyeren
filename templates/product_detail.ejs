<%- include('header') %>
<div class="row">
    <div class="col-lg-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">首页</a></li>
                <li class="breadcrumb-item"><a href="/products?category=<%= product.category_id %>"><%= product.category_name %></a></li>
                <li class="breadcrumb-item active"><%= product.title %></li>
            </ol>
        </nav>
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="mb-3">
                    <% if(product.file_type){ %><span class="badge bg-secondary fs-6 me-1"><%= product.file_type %></span><% } %>
                    <span class="badge bg-light text-dark fs-6"><%= product.category_name %></span>
                </div>
                <h3 class="fw-bold"><%= product.title %></h3>
                <div class="d-flex gap-3 text-muted small mb-3">
                    <span><i class="bi bi-download"></i> <%= product.download_count %> 次下载</span>
                    <% if(product.file_size){ %><span><i class="bi bi-hdd"></i> <%= product.file_size %></span><% } %>
                    <span><i class="bi bi-calendar"></i> <%= product.created_date %></span>
                </div>
                <% if(product.tags){ %>
                    <div class="mb-3">
                        <% product.tags.split(',').filter(Boolean).forEach(function(tag) { %>
                            <a href="/products?search=<%= tag.trim() %>" class="badge bg-info text-decoration-none me-1">#<%= tag.trim() %></a>
                        <% }); %>
                    </div>
                <% } %>
                <p class="mb-4"><%= product.description || '暂无描述' %></p>
                <% if (!user) { %>
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle fs-4 me-2"></i>
                        <div>请 <a href="/login?redirect=/products/<%= product.id %>" class="alert-link">登录</a> 后下载资料</div>
                    </div>
                <% } else if (!user.is_member) { %>
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-gem fs-4 me-2"></i>
                        <div>仅限会员下载，<a href="/membership" class="alert-link">开通会员</a> 后即可免费下载全部资料</div>
                    </div>
                <% } else { %>
                    <a href="/download/<%= product.id %>" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-download"></i> 下载资料
                    </a>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h6 class="fw-bold"><i class="bi bi-info-circle"></i> 关于会员</h6>
                <p class="small text-muted mb-2">开通会员后，所有资料全部免费下载!</p>
                <ul class="small text-muted ps-3 mb-2">
                    <li>无限下载所有资料</li>
                    <li>邀请3人返还会员费</li>
                    <li>持续更新资料库</li>
                </ul>
                <% if (!user || !user.is_member) { %>
                    <a href="/membership" class="btn btn-warning btn-sm w-100">开通会员 ￥10</a>
                <% } %>
            </div>
        </div>
        <% if (related && related.length > 0) { %>
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="fw-bold"><i class="bi bi-link"></i> 相关推荐</h6>
                    <div class="list-group list-group-flush">
                        <% related.forEach(function(r) { %>
                            <a href="/products/<%= r.id %>" class="list-group-item list-group-item-action small"><%= r.title %></a>
                        <% }); %>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>
<%- include('footer') %>
