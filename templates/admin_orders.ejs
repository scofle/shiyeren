<%- include('header') %>
<h4 class="fw-bold mb-3"><i class="bi bi-receipt"></i> 订单管理</h4>
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>ID</th><th>用户</th><th>类型</th><th>金额</th><th>状态</th><th>创建时间</th><th>支付时间</th></tr>
                </thead>
                <tbody>
                    <% orders.forEach(function(o) { %>
                        <tr>
                            <td><%= o.id %></td>
                            <td><%= o.username %></td>
                            <td><%= o.order_type === 'membership' ? '会员开通' : '推广返现' %></td>
                            <td>￥<%= o.amount %></td>
                            <td><% if (o.status === 'completed') { %><span class="badge bg-success">已完成</span><% } else { %><span class="badge bg-warning">待支付</span><% } %></td>
                            <td class="small"><%= o.created_date %></td>
                            <td class="small"><%= o.paid_date || '-' %></td>
                        </tr>
                    <% }); %>
                    <% if (orders.length === 0) { %>
                        <tr><td colspan="7" class="text-center text-muted py-4">暂无订单</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('footer') %>
