<%- include('header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-box"></i> 商品管理</h4>
    <a href="/admin/products/new" class="btn btn-primary"><i class="bi bi-plus-circle"></i> 新增商品</a>
</div>
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>标题</th>
                        <th>分类</th>
                        <th>下载次数</th>
                        <th>状态</th>
                        <th>创建时间</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(function(p) { %>
                        <tr>
                            <td><%= p.id %></td>
                            <td><%= p.title %></td>
                            <td><%= p.category_name %></td>
                            <td><%= p.download_count %></td>
                            <td><% if (p.is_active) { %><span class="badge bg-success">上架</span><% } else { %><span class="badge bg-secondary">下架</span><% } %></td>
                            <td class="small"><%= p.created_date %></td>
                            <td>
                                <a href="/admin/products/edit/<%= p.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form method="POST" action="/admin/products/delete/<%= p.id %>" style="display:inline" onsubmit="return confirm('确定删除?')">
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                    <% if (products.length === 0) { %>
                        <tr><td colspan="7" class="text-center text-muted py-4">暂无商品</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('footer') %>
