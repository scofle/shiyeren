<%- include('header') %>

<!-- Hero -->
<div class="bg-primary text-white p-5 rounded-4 mb-4 shadow">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h1 class="display-4 fw-bold">海量虚拟资料库</h1>
            <p class="lead mb-4">电子书、模板、设计资源、课程教程、软件工具 —— 一站式获取</p>
            <% if (!user) { %>
                <a href="/register" class="btn btn-light btn-lg me-2">立即注册</a>
                <a href="/membership" class="btn btn-outline-light btn-lg">开通会员</a>
            <% } else if (!user.is_member) { %>
                <a href="/membership" class="btn btn-light btn-lg">开通会员 ￥10</a>
            <% } else { %>
                <a href="/products" class="btn btn-light btn-lg">浏览资料</a>
            <% } %>
        </div>
        <div class="col-lg-5 text-center d-none d-lg-block">
            <i class="bi bi-box-seam" style="font-size: 8rem; opacity: 0.6;"></i>
        </div>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 text-primary"><%= typeof stats !== 'undefined' && stats ? stats.week_downloads : 0 %></div>
            <div class="text-muted small">本周下载</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 text-success"><%= products ? products.length : 0 %></div>
            <div class="text-muted small">资料总数</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 text-warning"><%= typeof stats !== 'undefined' && stats ? stats.week_new_members : 0 %></div>
            <div class="text-muted small">本周新增会员</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 text-info">￥<%= typeof stats !== 'undefined' && stats ? stats.week_revenue : 0 %></div>
            <div class="text-muted small">本周收入</div>
        </div>
    </div>
</div>

<!-- Categories -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0"><i class="bi bi-grid"></i> 资料分类</h4>
    </div>
    <div class="row g-2">
        <% if (typeof categories !== 'undefined' && categories) { %>
            <% categories.forEach(function(cat) { %>
                <div class="col-md-2 col-4">
                    <a href="/products?category=<%= cat.id %>" class="text-decoration-none">
                        <div class="card border-0 bg-light text-center p-3 h-100 hover-shadow">
                            <div class="fs-1"><% if(cat.name=='电子书'){%><i class="bi bi-book"></i><%}else if(cat.name=='模板素材'){%><i class="bi bi-files"></i><%}else if(cat.name=='设计资源'){%><i class="bi bi-palette"></i><%}else if(cat.name=='课程教程'){%><i class="bi bi-play-btn"></i><%}else if(cat.name=='软件工具'){%><i class="bi bi-tools"></i><%}else{%><i class="bi bi-folder"></i><%}%></div>
                            <div class="small mt-1"><%= cat.name %></div>
                        </div>
                    </a>
                </div>
            <% }); %>
        <% } %>
    </div>
</div>

<!-- Latest Products -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0"><i class="bi bi-clock-history"></i> 最新资料</h4>
        <a href="/products" class="btn btn-outline-primary btn-sm">查看全部 <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="row g-3">
        <% if (products && products.length > 0) { %>
            <% products.forEach(function(p) { %>
                <div class="col-md-3 col-6">
                    <div class="card border-0 shadow-sm h-100 product-card">
                        <div class="card-body">
                            <div class="mb-2">
                                <% if(p.file_type){ %><span class="badge bg-secondary"><%= p.file_type %></span><% } %>
                                <span class="badge bg-light text-dark"><%= p.category_name %></span>
                            </div>
                            <h6 class="card-title"><a href="/products/<%= p.id %>" class="text-decoration-none text-dark stretched-link"><%= p.title %></a></h6>
                            <p class="card-text text-muted small"><%= (p.description || '').substring(0, 60) %></p>
                            <div class="d-flex justify-content-between text-muted small mt-auto">
                                <span><i class="bi bi-download"></i> <%= p.download_count %></span>
                                <% if(p.file_size){ %><span><%= p.file_size %></span><% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                暂无资料，请等待管理员上传
            </div>
        <% } %>
    </div>
</div>

<!-- Membership CTA -->
<div class="bg-gradient bg-dark text-white p-4 rounded-4 mb-4">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <h4 class="fw-bold"><i class="bi bi-gem"></i> 开通会员，全部免费下载!</h4>
            <p class="mb-0 text-muted">仅需 ￥10 即可享受所有资料无限下载。邀请3位好友充值还可全额返现!</p>
        </div>
        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
            <a href="/membership" class="btn btn-warning btn-lg fw-bold">立即开通 ￥10</a>
        </div>
    </div>
</div>

<%- include('footer') %>
