<%- include('header') %>
<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body text-center p-4">
                <div class="display-1 mb-2"><i class="bi bi-person-circle text-primary"></i></div>
                <h5><%= user.username %></h5>
                <p class="text-muted small"><%= user.email %></p>
                <% if (user.is_member) { %>
                    <span class="badge bg-warning text-dark fs-6"><i class="bi bi-gem"></i> 会员</span>
                <% } else { %>
                    <a href="/membership" class="btn btn-warning btn-sm">开通会员</a>
                <% } %>
                <div class="mt-3 text-start small text-muted">
                    <div><i class="bi bi-calendar"></i> 注册时间: <%= user.registered_date %></div>
                    <div><i class="bi bi-people"></i> 推广人数: <%= refCount %>/3</div>
                    <div><i class="bi bi-coin"></i> 余额: ￥<%= user.balance || 0 %></div>
                </div>
            </div>
        </div>
        <div class="d-grid gap-2">
            <a href="/referral" class="btn btn-outline-primary"><i class="bi bi-share"></i> 推广中心</a>
            <a href="/membership" class="btn btn-outline-warning"><i class="bi bi-gem"></i> 会员中心</a>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> 下载记录</h5>
            </div>
            <div class="card-body p-0">
                <% if (downloads.length > 0) { %>
                    <div class="list-group list-group-flush">
                        <% downloads.forEach(function(d) { %>
                            <a href="/products/<%= d.product_id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-bold"><%= d.product_title %></div>
                                    <small class="text-muted"><%= d.downloaded_at %></small>
                                </div>
                                <i class="bi bi-download text-muted"></i>
                            </a>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        暂无下载记录
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
<%- include('footer') %>
