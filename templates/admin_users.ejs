<%- include('header') %>
<h4 class="fw-bold mb-3"><i class="bi bi-people"></i> 用户管理</h4>
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>ID</th><th>用户名</th><th>邮箱</th><th>会员</th><th>推广数</th><th>下载数</th><th>余额</th><th>注册时间</th></tr>
                </thead>
                <tbody>
                    <% users.forEach(function(u) { %>
                        <tr>
                            <td><%= u.id %></td>
                            <td><%= u.username %> <% if (u.is_admin) { %><span class="badge bg-danger">管理员</span><% } %></td>
                            <td><%= u.email %></td>
                            <td><% if (u.is_member) { %><span class="badge bg-warning text-dark"><i class="bi bi-gem"></i> 会员</span><% } else { %><span class="badge bg-secondary">普通</span><% } %></td>
                            <td><%= u.referral_count || 0 %></td>
                            <td><%= u.download_count || 0 %></td>
                            <td>￥<%= u.balance || 0 %></td>
                            <td class="small"><%= u.registered_date %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('footer') %>
