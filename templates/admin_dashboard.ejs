<%- include('header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2"></i> 管理后台</h4>
    <div>
        <a href="/admin/report" class="btn btn-primary btn-sm"><i class="bi bi-file-text"></i> 生成周报</a>
        <a href="/admin/products" class="btn btn-success btn-sm"><i class="bi bi-plus-circle"></i> 商品管理</a>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3 bg-primary text-white">
            <div class="fs-3 fw-bold"><%= stats.week_downloads %></div>
            <div class="small">本周下载</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3 bg-success text-white">
            <div class="fs-3 fw-bold"><%= stats.week_new_members %></div>
            <div class="small">本周新会员</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3 bg-warning text-dark">
            <div class="fs-3 fw-bold">￥<%= stats.week_revenue %></div>
            <div class="small">本周收入</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center p-3 bg-info text-white">
            <div class="fs-3 fw-bold"><%= stats.week_new_products %></div>
            <div class="small">本周新增</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold">下载趋势 (近14天)</h6>
            </div>
            <div class="card-body">
                <canvas id="downloadChart" height="250"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h6 class="mb-0 fw-bold">本周热门 TOP 5</h6>
            </div>
            <div class="card-body p-0">
                <% if (stats.top_products && stats.top_products.length > 0) { %>
                    <div class="list-group list-group-flush">
                        <% stats.top_products.forEach(function(p, i) { %>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><%= i+1 %>. <%= p.title %></span>
                                <span class="badge bg-primary rounded-pill"><%= p.cnt %></span>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-4 text-muted small">本周暂无下载数据</div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Product download stats -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white">
        <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart"></i> 商品下载统计</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>商品名称</th>
                        <th>总下载</th>
                        <th>本周下载</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (productStats && productStats.length > 0) { %>
                        <% productStats.forEach(function(p, i) { %>
                            <tr>
                                <td><%= i+1 %></td>
                                <td><a href="/products/<%= p.id %>" class="text-decoration-none"><%= p.title %></a></td>
                                <td><%= p.download_count %></td>
                                <td><span class="badge bg-<%= p.week_downloads > 0 ? 'success' : 'secondary' %>"><%= p.week_downloads %></span></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="4" class="text-center text-muted py-3">暂无数据</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<% if (report) { %>
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold"><i class="bi bi-file-text"></i> 最新周报</h6>
        <small class="text-muted"><%= report.week_start %> ~ <%= report.week_end %></small>
    </div>
    <div class="card-body">
        <p class="mb-1"><strong>建议:</strong> <%= report.suggestions %></p>
    </div>
</div>
<% } %>

<script>
const ctx = document.getElementById('downloadChart').getContext('2d');
const dailyStats = <%- JSON.stringify(dailyStats || []) %>;
new Chart(ctx, {
    type: 'line',
    data: {
        labels: dailyStats.map(d => d.stat_date || ''),
        datasets: [{
            label: '下载量',
            data: dailyStats.map(d => d.total_downloads || 0),
            borderColor: '#0d6efd',
            backgroundColor: 'rgba(13,110,253,0.1)',
            fill: true
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
});
</script>
<%- include('footer') %>
