<%- include('header') %>
<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-plus-circle"></i> 新增分类</h5>
            </div>
            <div class="card-body">
                <form method="POST" action="/admin/categories/new">
                    <div class="mb-3">
                        <label class="form-label">分类名称</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">描述</label>
                        <input type="text" name="description" class="form-control">
                    </div>
                    <button type="submit" class="btn btn-primary">添加</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-grid"></i> 分类列表</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>ID</th><th>名称</th><th>描述</th><th>操作</th></tr>
                    </thead>
                    <tbody>
                        <% categories.forEach(function(c) { %>
                            <tr>
                                <td><%= c.id %></td>
                                <td><%= c.name %></td>
                                <td><%= c.description %></td>
                                <td>
                                    <form method="POST" action="/admin/categories/delete/<%= c.id %>" style="display:inline" onsubmit="return confirm('确定删除?')">
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<%- include('footer') %>
