<%- include('header') %>
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h6 class="fw-bold"><i class="bi bi-funnel"></i> 分类筛选</h6>
                <div class="list-group list-group-flush">
                    <a href="/products" class="list-group-item list-group-item-action <%= !currentCat ? 'active' : '' %>">全部</a>
                    <% categories.forEach(function(c) { %>
                        <a href="/products?category=<%= c.id %><%= search ? '&search=' + search : '' %>" class="list-group-item list-group-item-action <%= String(currentCat) === String(c.id) ? 'active' : '' %>"><%= c.name %></a>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0"><i class="bi bi-collection"></i> <%= title %></h4>
            <span class="text-muted small">共 <%= products.length %> 个资料</span>
        </div>
        <form class="mb-3" method="GET" action="/products">
            <% if (currentCat) { %><input type="hidden" name="category" value="<%= currentCat %>"><% } %>
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="搜索资料名称..." value="<%= search || '' %>">
                <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i> 搜索</button>
            </div>
        </form>
        <div class="row g-3">
            <% if (products.length > 0) { %>
                <% products.forEach(function(p) { %>
                    <div class="col-md-4 col-6">
                        <div class="card border-0 shadow-sm h-100 product-card">
                            <div class="card-body d-flex flex-column">
                                <div class="mb-2">
                                    <% if(p.file_type){ %><span class="badge bg-secondary"><%= p.file_type %></span><% } %>
                                    <span class="badge bg-light text-dark"><%= p.category_name %></span>
                                </div>
                                <h6 class="card-title"><a href="/products/<%= p.id %>" class="text-decoration-none text-dark stretched-link"><%= p.title %></a></h6>
                                <p class="card-text text-muted small flex-grow-1"><%= (p.description || '').substring(0, 80) %></p>
                                <div class="d-flex justify-content-between text-muted small mt-auto pt-2 border-top">
                                    <span><i class="bi bi-download"></i> <%= p.download_count %>次下载</span>
                                    <% if(p.file_size){ %><span><%= p.file_size %></span><% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <% if (search) { %>没有找到相关"<%= search %>"的资料<% } else { %>暂无可用的资料<% } %>
                </div>
            <% } %>
        </div>
    </div>
</div>
<%- include('footer') %>
