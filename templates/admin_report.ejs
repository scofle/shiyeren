<%- include('header') %>
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0"><i class="bi bi-file-text"></i> 运营周报</h4>
            <a href="/admin/report" class="btn btn-primary"><i class="bi bi-arrow-repeat"></i> 生成最新周报</a>
        </div>
        <% if (report) { %>
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white d-flex justify-content-between">
                    <h5 class="mb-0">周报: <%= report.week_start %> ~ <%= report.week_end %></h5>
                    <span class="text-muted small"><%= report.created_date %></span>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-4">
                        <div class="col-md-3 col-6">
                            <div class="card bg-primary text-white text-center p-3">
                                <div class="fs-3 fw-bold"><%= report.total_downloads %></div>
                                <div class="small">总下载量</div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="card bg-success text-white text-center p-3">
                                <div class="fs-3 fw-bold"><%= report.new_members %></div>
                                <div class="small">新增会员</div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="card bg-warning text-dark text-center p-3">
                                <div class="fs-3 fw-bold">￥<%= report.total_revenue %></div>
                                <div class="small">总收入</div>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="card bg-info text-white text-center p-3">
                                <div class="fs-3 fw-bold"><%= report.top_products ? report.top_products.length : 0 %></div>
                                <div class="small">热门资料</div>
                            </div>
                        </div>
                    </div>

                    <% if (report.top_products && report.top_products.length > 0) { %>
                        <h6 class="fw-bold">本周热门资料 TOP 5</h6>
                        <ol class="mb-4">
                            <% report.top_products.forEach(function(p) { %>
                                <li class="mb-1"><%= p.title %> - <span class="text-muted"><%= p.count %> 次下载</span></li>
                            <% }); %>
                        </ol>
                    <% } %>

                    <div class="bg-light rounded p-4">
                        <h6 class="fw-bold text-primary"><i class="bi bi-lightbulb"></i> 运营建议</h6>
                        <% if (report.suggestions) { %>
                            <% report.suggestions.split(';').forEach(function(s) { %>
                                <p class="mb-1"><%= s.trim() %></p>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="card shadow-sm border-0">
                <div class="card-body text-center py-5 text-muted">
                    <i class="bi bi-file-earmark-text fs-1 d-block mb-2"></i>
                    暂无周报数据，点击上方按钮生成
                </div>
            </div>
        <% } %>
    </div>
</div>
<%- include('footer') %>
